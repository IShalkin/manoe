# =============================================================================
# MANOE - Multi-Agent Narrative Orchestration Engine
# Environment Configuration for Docker Compose
# =============================================================================
#
# Copy this file to .env and configure your values before running:
#   docker-compose up -d
#
# =============================================================================

# =============================================================================
# LLM Provider API Keys (BYOK - Bring Your Own Key)
# Configure at least one provider to use the system
# =============================================================================

# OpenAI Configuration
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_ORG_ID=

# OpenRouter Configuration (access multiple models through one API)
# Get your API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-openrouter-api-key

# Google Gemini Configuration
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# Anthropic Claude Configuration
# Get your API key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# =============================================================================
# Frontend (Vite)
# =============================================================================
# These variables are consumed by the frontend build/runtime.
# When using docker-compose.yml, these are passed into the frontend container.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Base URL for the API Gateway orchestrator endpoints
VITE_ORCHESTRATOR_URL=http://localhost:3000/orchestrate

# =============================================================================
# Available Models by Provider
# =============================================================================
#
# OpenAI:
#   - gpt-5.5 (recommended for most agents)
#   - gpt-5.4-mini (cost-effective for writer)
#   - gpt-5.4-nano (fastest, cheapest)
#
# OpenRouter (access multiple providers):
#   - openai/gpt-5.5
#   - anthropic/claude-opus-4.8
#   - google/gemini-3.1-pro-preview
#   - deepseek/deepseek-v3.2
#
# Google Gemini:
#   - gemini-3.1-pro-preview (recommended)
#   - gemini-3.5-flash
#   - gemini-3.1-flash-lite (fastest, cheapest)
#
# Anthropic Claude:
#   - claude-opus-4-8 (recommended)
#   - claude-sonnet-4-7
#   - claude-haiku-4-5 (fast, cost-effective)
#
# =============================================================================

# =============================================================================
# API Gateway / Backend (used by docker-compose.vps.yml)
# =============================================================================

# Supabase URL (Kong URL if self-hosted)
SUPABASE_URL=

# JWT token expiration
JWT_EXPIRES_IN=7d

# Langfuse (optional observability)
LANGFUSE_HOST=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Email used by nginx-proxy companion (docker-compose.vps.yml)
LETSENCRYPT_EMAIL=

# =============================================================================
# Service Ports (change if you have conflicts)
# =============================================================================

FRONTEND_PORT=5173
REDIS_PORT=6379
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# =============================================================================
# Security (CHANGE IN PRODUCTION!)
# =============================================================================

# REQUIRED: JWT signing secret. docker-compose.vps.yml fails to start if unset.
# Generate with: openssl rand -base64 32
JWT_SECRET=
SUPABASE_KEY=your-supabase-service-key

# =============================================================================
# Langfuse Self-Hosted Secrets (REQUIRED by docker-compose.vps.yml)
# =============================================================================
# These have NO insecure defaults: compose errors out if any is missing/empty.
# Generate a fresh value for each; never reuse the placeholders below.

# Postgres password for the bundled langfuse-postgres
LANGFUSE_DB_PASSWORD=  # REQUIRED: generate with: openssl rand -base64 24
# Salt for Langfuse API-key hashing / key derivation
LANGFUSE_SALT=  # REQUIRED: random 32+ char salt, generate with: openssl rand -hex 32
# Encryption key for secrets at rest (MUST be exactly 64 hex chars / 32 bytes)
LANGFUSE_ENCRYPTION_KEY=  # REQUIRED: generate with: openssl rand -hex 32
# NextAuth session secret for the Langfuse web UI
LANGFUSE_NEXTAUTH_SECRET=  # REQUIRED: generate with: openssl rand -base64 32
# ClickHouse password for the bundled langfuse-clickhouse
LANGFUSE_CLICKHOUSE_PASSWORD=  # REQUIRED: generate with: openssl rand -base64 24
# Redis password (requirepass) for the bundled langfuse-redis
LANGFUSE_REDIS_PASSWORD=  # REQUIRED: generate with: openssl rand -base64 24
# MinIO root password + S3 secret access key for the bundled langfuse-minio
# (leaving this unset would otherwise leave the S3 bucket open)
LANGFUSE_MINIO_PASSWORD=  # REQUIRED: generate with: openssl rand -base64 24

# =============================================================================
# LLM-as-a-Judge (observability only — gates nothing)
# =============================================================================

# Default-ON when an API key is available. Set to "false" to disable.
EVALUATION_ENABLED=
# Judge provider/model (cheap model is fine; runs N samples at temperature 0)
EVALUATION_LLM_PROVIDER=openai
EVALUATION_LLM_MODEL=gpt-5.4-mini
# EVALUATION_LLM_API_KEY falls back to OPENAI_API_KEY if unset
EVALUATION_LLM_API_KEY=
# Self-consistency sample count (median reported). Default 3.
EVALUATION_SAMPLES=3

# =============================================================================
# Optional: Redis Password (recommended for production)
# =============================================================================

REDIS_PASSWORD=

# =============================================================================
# Optional: Qdrant API Key (if using Qdrant Cloud)
# =============================================================================

QDRANT_API_KEY=

# =============================================================================
# Logging
# =============================================================================

LOG_LEVEL=info
# For api-gateway when running outside Docker.
NODE_ENV=development
# CORS_ORIGIN: Comma-separated list of allowed origins, or * for all
# For production with local development: https://manoe.iliashalkin.com,http://localhost:5173
CORS_ORIGIN=*
