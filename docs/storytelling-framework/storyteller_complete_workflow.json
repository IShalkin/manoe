[
  {
    "name": "Storyteller Framework Complete Workflow",
    "description": "12-stage AI-powered story generation framework",
    "nodes": [
      {
        "parameters": {},
        "name": "Start",
        "type": "n8n-nodes-base.start",
        "typeVersion": 1,
        "position": [100, 300]
      },
      {
        "parameters": {
          "httpMethod": "POST",
          "path": "story/create",
          "options": {
            "responseMode": "responseNode",
            "responseData": "allEntries"
          }
        },
        "name": "Webhook - Entry",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1,
        "position": [300, 300]
      },
      {
        "parameters": {
          "authentication": "genericCredentialType",
          "genericAuthType": "httpHeaderAuth",
          "nodeCredentialName": "OpenAI API",
          "options": {
            "allowUnauthorizedCerts": false,
            "response": {
              "response": {
                "fullResponse": true,
                "responseFormat": "json"
              }
            }
          }
        },
        "name": "OpenAI - Initialize",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [500, 300]
      },
      {
        "parameters": {
          "values": {
            "string": [
              {
                "name": "seedIdea",
                "value": "={{ $json.body.seedIdea }}"
              },
              {
                "name": "title",
                "value": "={{ $json.body.title || 'Untitled Story' }}"
              }
            ]
          },
          "options": {}
        },
        "name": "Set - Extract Request Data",
        "type": "n8n-nodes-base.set",
        "typeVersion": 1,
        "position": [500, 450]
      },
      {
        "parameters": {
          "keepOnlySet": true,
          "values": {
            "string": [
              {
                "name": "storyId",
                "value": "={{ UUID.V4() }}"
              },
              {
                "name": "timestamp",
                "value": "={{ DateTime.now().toISO() }}"
              },
              {
                "name": "status",
                "value": "initializing"
              },
              {
                "name": "seedIdea",
                "value": "={{ $json.seedIdea }}"
              },
              {
                "name": "title",
                "value": "={{ $json.title }}"
              }
            ],
            "object": [
              {
                "name": "metadata",
                "value": {
                  "version": "1.0",
                  "framework": "storyteller",
                  "stage": "genesis",
                  "aiModels": {
                    "primary": "gpt-4",
                    "creative": "deepseek-r",
                    "rapid": "o1"
                  }
                }
              }
            ]
          },
          "options": {}
        },
        "name": "Set - Initialize Story",
        "type": "n8n-nodes-base.set",
        "typeVersion": 1,
        "position": [700, 300]
      },
      {
        "parameters": {
          "operation": "insert",
          "schema": "public",
          "table": "stories",
          "columns": "id,title,seed_idea,moral_compass,target_audience,framework,status,created_at,metadata",
          "values": {
            "id": "={{ $json.storyId }}",
            "title": "={{ $json.title }}",
            "seed_idea": "={{ $json.seedIdea }}",
            "moral_compass": "={{ $json.moralCompass }}",
            "target_audience": "={{ $json.targetAudience }}",
            "framework": "standard",
            "status": "={{ $json.status }}",
            "created_at": "={{ $json.timestamp }}",
            "metadata": "={{ $json.metadata }}"
          }
        },
        "name": "PostgreSQL - Create Story",
        "type": "n8n-nodes-base.postgres",
        "typeVersion": 1,
        "position": [900, 300]
      },
      {
        "parameters": {
          "command": "set",
          "key": "={{ 'story:' + $json.storyId + ':status' }}",
          "value": "={{ $json.status }}",
          "options": {
            "expireTime": 86400
          }
        },
        "name": "Redis - Set Status",
        "type": "n8n-nodes-base.redis",
        "typeVersion": 1,
        "position": [1100, 300]
      },
      {
        "parameters": {
          "values": {
            "string": [
              {
                "name": "moralCompass",
                "value": "={{ $json.body.moralCompass }}"
              }
            ]
          },
          "options": {}
        },
        "name": "Set - Define Moral Compass",
        "type": "n8n-nodes-base.set",
        "typeVersion": 1,
        "position": [300, 450]
      },
      {
        "parameters": {
          "values": {
            "string": [
              {
                "name": "targetAudience",
                "value": "={{ $json.body.targetAudience }}"
              }
            ]
          },
          "options": {}
        },
        "name": "Set - Target Audience",
        "type": "n8n-nodes-base.set",
        "typeVersion": 1,
        "position": [500, 450]
      },
      {
        "parameters": {
          "url": "={{ $env.OPENAI_API_URL }}/v1/chat/completions",
          "authentication": "headerAuth",
          "headerParameters": {
            "parameters": [
              {
                "name": "Authorization",
                "value": "Bearer ={{ $env.OPENAI_API_KEY }}"
              }
            ]
          },
          "sendBody": true,
          "bodyParameters": {
            "parameters": [
              {
                "name": "model",
                "value": "gpt-4"
              },
              {
                "name": "messages",
                "value": [
                  {
                    "role": "system",
                    "content": "You are a storytelling assistant specializing in narrative possibilities analysis."
                  },
                  {
                    "role": "user",
                    "content": "={{ 'Generate narrative possibilities for this story idea: ' + $json.seedIdea }}"
                  }
                ]
              },
              {
                "name": "temperature",
                "value": 0.7
              }
            ]
          },
          "options": {}
        },
        "name": "AI Agent - Generate Narrative Possibilities",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [700, 450]
      },
      {
        "parameters": {
          "conditions": {
            "string": [
              {
                "value1": "={{ $json.body.narrativeFramework }}",
                "operation": "equals",
                "value2": "Hero's Journey"
              }
            ]
          }
        },
        "name": "Switch - Choose Framework",
        "type": "n8n-nodes-base.switch",
        "typeVersion": 1,
        "position": [900, 450]
      },
      {
