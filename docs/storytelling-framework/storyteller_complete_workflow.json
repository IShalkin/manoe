          "headerParameters": {
            "parameters": [
              {
                "name": "Authorization",
                "value": "Bearer ={{ $env.OPENAI_API_KEY }}"
              }
            ]
          },
          "sendBody": true,
          "bodyParameters": {
            "parameters": [
              {
                "name": "model",
                "value": "gpt-4"
              },
              {
                "name": "messages",
                "value": [
                  {
                    "role": "system",
                    "content": "You are a narrative framework specialist."
                  },
                  {
                    "role": "user",
                    "content": "={{ 'Analyze and choose the best framework for this story: ' + $json.seedIdea }}"
                  }
